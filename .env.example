# ══════════════════════════════════════════════════════════
#  Professora Sofia — Configuração de Ambiente
# ══════════════════════════════════════════════════════════

LLM_PROVIDER=openrouter

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-COLOQUE-SUA-CHAVE-AQUI

# 100% gratuito (sem gastar créditos da conta)
OPENROUTER_MODEL=mistralai/mistral-nemo
OPENROUTER_FALLBACK_MODELS=deepseek/deepseek-v4-flash,google/gemini-2.0-flash-001,openrouter/free
OPENROUTER_MODELOS_RAPIDOS=mistralai/mistral-nemo,deepseek/deepseek-v4-flash,google/gemini-2.0-flash-001,openrouter/free
OPENROUTER_APENAS_GRATUITOS=true
OPENROUTER_PRIORIDADE_RAPIDO=true

# Alternativa 100% grátis direto no Google (sem OpenRouter):
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=AIzaSy-...  https://aistudio.google.com/apikey

APP_URL=http://localhost:3030
APP_NAME=Professora Sofia MVP
PORT=3030

# D-ID — lip-sync da Professora Sofia (https://www.d-id.com/)
# Crie a chave em: Studio → Account Settings → API
DID_API_KEY=
DID_ENABLED=true
DID_VOICE_PROVIDER=microsoft
DID_VOICE_ID=en-US-JennyNeural
# Opcional: URL pública da foto (se APP_URL for localhost, o servidor envia a imagem à D-ID)
# DID_SOURCE_URL=
DID_MAX_CHARS=380
DID_TIMEOUT_MS=90000
